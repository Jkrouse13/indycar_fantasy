<div class="main-container">
  <div class="container-fluid">
    <h3>Import Latest Race Results from TheSportsDB</h3>

    <div class="row" style="margin-top: 20px;">
      <div class="col-md-5">
        <div class="panel panel-default">
          <div class="panel-heading"><strong>TheSportsDB — Most Recent Finished Race</strong></div>
          <div class="panel-body">
            <% if @preview[:api_event] %>
              <p><strong>Event:</strong> <%= @preview[:api_event]["strEvent"] %></p>
              <p><strong>Date:</strong> <%= @preview[:api_event]["dateEvent"] %></p>
              <p><strong>Round:</strong> <%= @preview[:api_event]["intRound"] %></p>
              <p><strong>Results:</strong> <%= @preview[:parsed_rows].size %> drivers</p>
            <% else %>
              <p class="text-muted">No finished race found in TheSportsDB for this season.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-md-1 text-center" style="padding-top: 60px; font-size: 24px;">
        <% if @preview[:match] %>
          <span class="text-success"><i class="fas fa-check-circle"></i></span>
        <% else %>
          <span class="text-danger"><i class="fas fa-times-circle"></i></span>
        <% end %>
      </div>

      <div class="col-md-5">
        <div class="panel panel-default">
          <div class="panel-heading"><strong>DB — Next Unfinished Race</strong></div>
          <div class="panel-body">
            <% if @preview[:db_race] %>
              <p><strong>Race:</strong> <%= @preview[:db_race].name %></p>
              <p><strong>Date:</strong> <%= @preview[:db_race].date.to_date %></p>
              <p><strong>Status:</strong> <%= @preview[:db_race].status %></p>
            <% else %>
              <p class="text-muted">No unfinished races found in the database.</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <% if @preview[:match] %>
      <div class="alert alert-success">
        Dates match. <%= @preview[:parsed_rows].size %> results ready to import. Race will be marked <strong>final</strong>.
      </div>

      <table class="table table-striped table-condensed" style="margin-top: 10px; max-width: 400px;">
        <thead>
          <tr>
            <th>Pos</th>
            <th>#</th>
            <th>Driver</th>
            <th>In DB?</th>
          </tr>
        </thead>
        <tbody>
          <% @preview[:parsed_rows].each do |row| %>
            <% driver = Driver.find_by(car_number: row[:car_number]) %>
            <tr>
              <td><%= row[:finishing_position] %></td>
              <td><%= row[:car_number] %></td>
              <td><%= driver&.name || row[:car_number] %></td>
              <td>
                <% if driver %>
                  <span class="text-success">&#10003;</span>
                <% else %>
                  <span class="text-danger">&#10007; skip</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

    <% elsif @preview[:api_event] && @preview[:db_race] %>
      <div class="alert alert-danger">
        Dates do not match (<%= @preview[:api_event]["dateEvent"] %> vs <%= @preview[:db_race].date.to_date %>). No import will be performed.
      </div>
    <% end %>

    <div style="margin-top: 10px;">
      <% if @preview[:match] %>
        <%= form_tag rails_admin.import_latest_results_path(model_name: "race"), method: :post do %>
          <%= submit_tag "Import Results", class: "btn btn-primary" %>
          <%= link_to "Cancel", rails_admin.index_path(model_name: "race"), class: "btn btn-default" %>
        <% end %>
      <% else %>
        <%= link_to "Back to Races", rails_admin.index_path(model_name: "race"), class: "btn btn-default" %>
      <% end %>
    </div>
  </div>
</div>
